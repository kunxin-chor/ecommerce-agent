<%- contentFor('title') %>Products
<%- contentFor('body') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Products</h1>
  <a class="btn btn-primary" href="/admin/products/new">New Product</a>
</div>
<table class="table table-hover">
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Brand</th>
      <th>Category</th>
      <th>Price</th>
      <th>Stock</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
  <% products.forEach(p => { %>
    <tr>
      <td><%= p.id %></td>
      <td><%= p.name %></td>
      <td><%= p.brand %></td>
      <td><%= p.category_name %></td>
      <td>$<%= p.price %></td>
      <td><%= p.stock %></td>
      <td class="text-end">
        <a class="btn btn-sm btn-outline-secondary" href="/admin/products/<%= p.id %>/edit">Edit</a>
        <form method="post" action="/admin/products/<%= p.id %>/delete" class="d-inline">
          <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this product?');">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>
  </tbody>
</table>
